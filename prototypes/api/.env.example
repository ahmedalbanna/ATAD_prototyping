# Server
PORT=3001
NODE_ENV=development

# Database (SQLite — local file path, created automatically)
DATABASE_PATH=./data/atad.db

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# SMS (Twilio) — only needed for production SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
